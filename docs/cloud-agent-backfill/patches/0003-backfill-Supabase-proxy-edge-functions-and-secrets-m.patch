+type DialogueRow = {
+  type: string
+  timestamp: number | string
+  text: string
+}
+
+type HistoryMessage = {
+  role: 'user' | 'assistant'
+  content: string
+  timestamp: number
+}
+
+type HistoryGroup = {
+  id: string
+  title: string
+  startTime: number
+  endTime: number
